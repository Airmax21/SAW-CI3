#     ___ ___ _____ ___ _   _  ___  ___  ___ 
#    / __|_ _|_   _/ __| \ | |/ _ \| _ \/ __|
#   | (_ || |  | |  (_ |  \| | (_) |   /\__ \
#    \___|___| |_| \___|_|\_|\___/|_|_\|___/
#   =========================================
#   Standard .gitignore for CodeIgniter 3 + Composer

# --- [ Lingkungan Pengembangan / OS ] ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- [ IDE / Text Editor ] ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- [ Core CodeIgniter 3 Logs & Cache ] ---
application/logs/log-*.php
!application/logs/index.html

application/cache/*
!application/cache/index.html
!application/cache/.htaccess

# --- [ Custom Session Files (Jika menggunakan session driver 'files') ] ---
application/sessions/*
!application/sessions/index.html

# --- [ Vendor / Dependensi Third-Party ] ---
# Mengabaikan folder vendor hasil install composer
vendor/
composer.lock

# --- [ Database SQLite3 Internal ] ---
# Jika kamu menyimpan file database SQLite (.db / .sqlite) di dalam project,
# pastikan di-ignore agar data lokal tidak bocor atau konflik saat push/pull.
database.db
!application/database/seeds/